: 1777793412:0;nvim \
set -e\
CONFIG_DIR="$HOME/.config"\
BACKUP_DIR="$(pwd)"\
DATE=$(date +%Y-%m-%d)\
COMMIT_MSG="feat: dotfiles update $DATE"\
#\
ITEMS=(\
 "autostart"\
 "cava"\
 "starship.toml"\
 "fastfetch"\
 "MangoHud" \
 "goverlay"\
 "niri"\
)\
#\
mkdir -p "$BACKUP_DIR/.config"\
echo "Backing up dotfiles..."\
for item in "${ITEMS[@]}"; do\
 SRC="$CONFIG_DIR/$item"\
 DEST="$BACKUP_DIR/.config/$item"\
 \
 if [ -e "$SRC" ]; then\
 rm -rf "$DEST" \
 cp -a "$SRC" "$DEST"\
 echo "âƒ¼ƒ³ $item"\
 else\
 echo "âƒºƒ€ $item not found in ~/.config (skipped)"\
 fi\
done\
echo "Committing changes..."\
git add .config/\
git commit -m "$COMMIT_MSG"\
echo "Pushing to remote..."\
git push\
echo "Done! Dotfiles updated and pushed."
