// DMS Window Rules - Managed by DankMaterialShell
// Do not edit manually - changes may be overwritten

// @id=dms_rule_0 @name=
window-rule {
    match title="(?i).*meet.*"
    open-floating true
}

// @id=dms_rule_1 @name=
window-rule {
    match title="(?i).*(pip|picture[- ]?in[- ]?picture).*"
    open-floating true
}

// @id=dms_rule_4 @name=
window-rule {
    match app-id="^com\\.heroicgameslauncher\\.hgl$"
    opacity 1.00
}
